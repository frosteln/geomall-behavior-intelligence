AWS_REGION=ap-southeast-1
S3_BUCKET=your-model-bucket
MODEL_ROOT=/mnt/models
STACK_ROOT=/opt/llm-serving
PUBLIC_HOSTNAME=llm.example.com
OPENWEBUI_SECRET=replace-with-a-long-random-string
LITELLM_MASTER_KEY=replace-with-a-long-random-string
OPENWEBUI_PORT=3000
LITELLM_PORT=4000
VLLM_HOST=127.0.0.1
WHISPER_HOST=127.0.0.1
BERT_HOST=127.0.0.1
SYNC_MODELS_ON_BOOT=true
FORMAT_INSTANCE_STORE=true
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
VLLM_IMAGE=vllm/vllm-openai:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable
ACM_CERT_ARN=
